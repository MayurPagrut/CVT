# HuggingFace API Key
# Get yours at: https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_api_key_here

# Optional overrides
# Default base URL is the OpenAI-compatible Inference Providers router.
# HF_BASE_URL=https://router.huggingface.co/v1
# Model ID to use for chat completions.
# Tip: you can try adding a policy suffix like :fastest (e.g. deepseek-ai/DeepSeek-R1:fastest)
# HF_MODEL=google/gemma-3-27b-it
